{
  "name": "kq-call-summary",
  "main": "src/index.js",
  "compatibility_date": "2026-03-06",
  "observability": {
    "enabled": true
  },
  "vars": {
    // OpenAI-compatible Hugging Face router model used to generate the AI
    // session summary. ":fastest" lets the router pick a live provider.
    "HF_MODEL": "Qwen/Qwen2.5-7B-Instruct:fastest"
  }
}